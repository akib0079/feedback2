or_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","link":"","open_in_new_tab":false,"placeholder":"","padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0,"css":""},"blocks":{"text_6CJef9":{"type":"text","name":"t:names.text","settings":{"text":"<p>Find everything you need to care for your ZIENER products. From washing instructions and maintenance tips to re-impregnation guides, this section helps you preserve comfort, protection and performance for years to come.<\/p>","width":"fit-content","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"accordion_eFDxzy":{"type":"accordion","name":"t:names.accordion","settings":{"icon":"caret","dividers":true,"type_preset":"h6","inherit_color_scheme":true,"color_scheme":"","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{"accordion_row_gHXx7y":{"type":"_accordion-row","settings":{"heading":"Gloves","open_by_default":false,"icon":"none","width":20},"blocks":{"text_ALMWf8":{"type":"text","name":"t:names.heading","settings":{"text":"<p>All ZIENER gloves have sewn-in washing instructions that should be followed to ensure that the gloves remain functional for as long as possible.<\/p>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"custom","font":"var(--font-heading--family)","font_size":"1.125rem","line_height":"tight","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"image_gDXTGx":{"type":"image","name":"t:names.image","settings":{"image":"shopify:\/\/shop_images\/image_1.png","link":"","class":"service-product-care-image","image_ratio":"adapt","width":"px","custom_width":3,"width_px":"50px","width_mobile":"px","custom_width_mobile":5,"width_px_mobile":"50px","height":"fit","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"padding-block-start":40,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_PThikJ":{"type":"text","settings":{"text":"<h5>1. MACHINE WASH (GENTLE CYCLE) <\/h5><p>Please note the care symbols in the respective glove model!\u2028\u2028Gloves with this symbol can be washed on a delicate cycle, e.g. delicate wash or easy-care program, at a temperature of up to 30 °C. Please do not use fabric softener, chlorine bleach or wash-in impregnating agents. Pre-treat heavy stains, soak well, knead only gently and rinse well several times with clear water. Close the Velcro fasteners exactly before washing, as well as loops and zippers. Loosen the elastic bands and remove the inner gloves, if present. It is best to put the gloves in a separate laundry bag for washing. After washing, carefully squeeze out the water from the fingers to the wrist, do not wring! First wrap the gloves in a dry cloth and press lightly to dry them. Then leave to dry lying down.<br\/><\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":20,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"image_tRrnct":{"type":"image","name":"t:names.image","settings":{"image":"shopify:\/\/shop_images\/image_2.png","link":"","class":"service-product-care-image","image_ratio":"adapt","width":"px","custom_width":3,"width_px":"50px","width_mobile":"px","custom_width_mobile":5,"width_px_mobile":"50px","height":"fit","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"padding-block-start":40,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_3rMDch":{"type":"text","settings":{"text":"<h5>2. HAND WASH (NO MACHINE)<\/h5><p>Please note the care symbols in the respective glove model! \u2028\u2028Gloves with this symbol can be gently cleaned with a very soft, damp brush or a damp cotton cloth when dirty. The gloves can then be washed briefly by hand in warm water. Please do not use soapy cleaners and squeeze the water carefully from the fingers to the wrist, do not wring! First wrap the gloves in a dry cloth and press lightly to pre-dry them. Then leave to dry lying down. Please do not use fabric softener, chlorine bleach or wash-in impregnating agents. Pre-treat heavy stains, soak well, knead only gently and rinse well several times with clear water.<br\/><br\/><\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":20,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"image_7t3CYP":{"type":"image","name":"t:names.image","settings":{"image":"shopify:\/\/shop_images\/image_1.png","link":"","class":"service-product-care-image","image_ratio":"adapt","width":"px","custom_width":3,"width_px":"50px","width_mobile":"px","custom_width_mobile":5,"width_px_mobile":"50px","height":"fit","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"padding-block-start":40,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_fzAEJq":{"type":"text","settings":{"text":"<h5>3. DO NOT WASH<\/h5><p>Please observe the care symbols in the respective glove model!\u2028\u2028Gloves with this symbol can be gently cleaned with a very soft, damp brush or a damp cotton cloth if they become soiled. To do this, please moisten the very soft brush or cotton cloth and carefully rub the soiled areas out of the glove.<\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":20,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_KrwdJD":{"type":"text","settings":{"text":"<h5>4. ADDITIONAL CARE INSTRUCTIONS<\/h5><p>The first remedy for dirt, sweat, moisture or similar is to air out the gloves thoroughly and allow them to dry after use. Never dry gloves on or near a heater. Dry gloves can be kneaded softly on the hand to restore them to their original shape. Leather gloves or leather palms can also be sprayed or rubbed with a leather care product. They should also be dried in the fresh air, away from direct heat sources, hairdryers, underfloor heating and tumble dryers. We recommend impregnation after washing with a commercially available impregnating agent. Re-impregnate DWR-impregnated models with a spray or, depending on the care label, refresh the DWR with heat (light ironing). All gloves should only be stored perfectly dry, dust-free, dark and dry.<\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":40,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_ALMWf8","image_gDXTGx","text_PThikJ","image_tRrnct","text_3rMDch","image_7t3CYP","text_fzAEJq","text_KrwdJD"]},"accordion_row_FDmUiG":{"type":"_accordion-row","settings":{"heading":"Shipping","open_by_default":false,"icon":"none","width":20},"blocks":{"text_8TnXJx":{"type":"text","settings":{"text":"<p>We will work quickly to ship your order as soon as possible. Once your order has shipped, you will receive an email with further information. Delivery times vary depending on your location.<\/p>","width":"100%","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_8TnXJx"]},"accordion_row_xaLFUr":{"type":"_accordion-row","settings":{"heading":"Manufacturing","open_by_default":false,"icon":"none","width":20},"blocks":{"text_gGaDzb":{"type":"text","settings":{"text":"<p>Our products are manufactured both locally and globally. We carefully select our manufacturing partners to ensure our products are high quality and a fair value.<\/p>","width":"100%","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padd