<div class="section section--full-width-margin section--page-width section-id-{{ section.id }}">
  {% content_for 'block', type: '_tabs', id: 'service' %}
</div>
{% stylesheet %}
.section-service-tabs{
    padding: 50px 0 100px;
}
{% endstylesheet %}
<style>
@media screen and (max-width: 749px) {
  .layout-panel-flex--row:not(.mobile-column) {
    flex-wrap: var(--flex-wrap-mobile);
    height: auto;
    flex-direction: column;
    align-items: last baseline;
  }
  .image-block__image {
    object-fit: contain;
    aspect-ratio: var(--ratio);
  }
}
</style>
{% schema %}
{
  "name": "Service Tabs",
  "class": "section-service-tabs",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["aside"]
  },
  "settings": [
  ],
  "presets": [
    {
      "name": "Service Tabs"
    }
  ]
}
{% endschema %}
